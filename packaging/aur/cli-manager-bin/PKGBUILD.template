# Maintainer: CLI-Manager maintainers

pkgname=cli-manager-bin
_upstream_name=CLI-Manager
pkgver=1.2.7
pkgrel=1
pkgdesc="Cross-platform workspace for managing Claude Code and Codex CLI projects"
arch=('x86_64')
url="https://github.com/dark-hxx/CLI-Manager"
license=('AGPL-3.0-or-later')
depends=('gtk3' 'webkit2gtk-4.1' 'libayatana-appindicator' 'hicolor-icon-theme' 'desktop-file-utils')
provides=('cli-manager')
conflicts=('cli-manager' 'cli-manager-git')
options=('!strip' '!debug')

_deb="${_upstream_name}_${pkgver}_amd64.deb"
source=('cli-manager-wrapper')
source_x86_64=("${_deb}::${url}/releases/download/V${pkgver}/${_deb}")
sha256sums=('6fea143391e3c0a99571e76e9bb4122dfb6261f6d3af19bffc7dfd817715b137')
sha256sums_x86_64=('@DEB_SHA256@')
noextract=("${_deb}")

prepare() {
  rm -rf package-data
  mkdir -p package-data
  bsdtar -xf "${srcdir}/${_deb}" -C package-data data.tar.gz
}

package() {
  bsdtar -xf "${srcdir}/package-data/data.tar.gz" -C "${pkgdir}"

  install -d "${pkgdir}/usr/lib/CLI-Manager"
  mv "${pkgdir}/usr/bin/cli-manager" "${pkgdir}/usr/lib/CLI-Manager/cli-manager"
  # PTY 守护进程必须与主程序同目录（主程序按 current_exe 同目录查找）
  if [ -f "${pkgdir}/usr/bin/cli-manager-daemon" ]; then
    mv "${pkgdir}/usr/bin/cli-manager-daemon" "${pkgdir}/usr/lib/CLI-Manager/cli-manager-daemon"
  fi
  install -Dm0755 "${srcdir}/cli-manager-wrapper" "${pkgdir}/usr/bin/cli-manager"
}
